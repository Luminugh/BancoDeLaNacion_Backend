spring.application.name=banco-de-la-nacion-backend

server.port=8080

spring.datasource.url=jdbc:postgresql://localhost:5432/banco_nacion
spring.datasource.username=postgres
spring.datasource.password=postgres
spring.datasource.driver-class-name=org.postgresql.Driver

spring.jpa.hibernate.ddl-auto=update
spring.jpa.open-in-view=false
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.jdbc.time_zone=UTC
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect

springdoc.api-docs.path=/v3/api-docs
springdoc.swagger-ui.path=/swagger-ui.html

spring.sql.init.mode=never

bn.security.jwt.secret=change-me-later
bn.security.jwt.expiration-ms=86400000

bn.cors.allowed-origins=http://localhost:3000
